{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "./.github/tao/scripts/lint-hook.sh",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "./.github/tao/scripts/enforcement-hook.sh",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "./.github/tao/scripts/abex-hook.sh",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "./.github/tao/scripts/brainstorm-hook.sh",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "./.github/tao/scripts/plan-hook.sh",
        "timeout": 10
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "./.github/tao/scripts/context-hook.sh",
        "timeout": 5
      }
    ]
  }
}
